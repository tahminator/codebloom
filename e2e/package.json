{
    "name": "e2e",
    "version": "1.0.0",
    "description": "CodeBloom E2E",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "e2e-install": "pnpm exec playwright install --with-deps",
        "e2e": "pnpm run e2e-install && pnpm exec playwright test",
        "e2e-codegen": "pnpm run e2e-install && pnpx playwright codegen http://localhost:5173",
        "test": "pnpm run typecheck && pnpm run prettier && pnpm run lint",
        "fix": "pnpm run eslint:fix && pnpm run prettier:fix",
        "lint": "pnpm run eslint",
        "eslint": "eslint .",
        "eslint:fix": "eslint . --fix",
        "prettier": "prettier --check .",
        "prettier:fix": "prettier --write ."
    },
    "keywords": [],
    "author": "Tahmid Ahmed",
    "license": "MIT",
    "dependencies": {},
    "devDependencies": {
        "globals": "^17.4.0",
        "@eslint/js": "^9.39.2",
        "@playwright/test": "^1.58.2",
        "@types/bun": "^1.3.6",
        "@types/node": "^25.3.3",
        "eslint": "^9.0.2",
        "eslint-plugin-no-relative-import-paths": "^1.6.1",
        "eslint-plugin-perfectionist": "^5.3.1",
        "global": "^4.4.0",
        "prettier": "^3.8.0",
        "typescript": "^5.9.0",
        "typescript-eslint": "^8.53.0"
    },
    "patchedDependencies": {}
}
